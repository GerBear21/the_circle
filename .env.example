# The Circle - Environment Variables Example
# Copy this file to .env.local and fill in your values

# ===========================================
# Authentication (NextAuth.js)
# ===========================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# ===========================================
# Supabase Configuration
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ===========================================
# Optional: External Integrations
# ===========================================
# Microsoft Graph API (for Outlook integration)
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=

# Slack App Token (alternative to incoming webhooks)
# SLACK_BOT_TOKEN=

# Teams (typically uses incoming webhooks, configured per workflow)

# ===========================================
# HRIMS Integration (Separate Supabase Project)
# ===========================================
# Production points these at the real HRIMS project. Staging can point them at a
# throwaway "HRIMS DEMO" clone for demos (see database/demo/README.md).
HRIMS_SUPABASE_URL=https://your-hrims-project.supabase.co
HRIMS_SUPABASE_SERVICE_ROLE_KEY=your-hrims-service-role-key

# ===========================================
# Demo mode (STAGING ONLY — never set in production)
# ===========================================
# When DEMO_MODE=true, an email/password Credentials provider is enabled so
# controlled, non-Microsoft demo accounts (the demo_users table) can sign in.
# NEXT_PUBLIC_DEMO_MODE=true reveals the demo login form on the landing page.
# Leave BOTH unset in production so Azure AD remains the only login path.
# DEMO_MODE=true
# NEXT_PUBLIC_DEMO_MODE=true

# ===========================================
# Email Service (Resend)
# ===========================================
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=The Circle <noreply@yourdomain.com>
