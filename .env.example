# The Circle - Environment Variables Example
# Copy this file to .env.local and fill in your values

# ===========================================
# Authentication (NextAuth.js)
# ===========================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# ===========================================
# Supabase Configuration
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ===========================================
# Microsoft 365 integration (Graph, app-only)
# ===========================================
# Uses the same Azure AD app as sign-in. The app registration needs these
# Graph APPLICATION permissions with admin consent:
#   Mail.Send            (Outlook notification emails)
#   Files.ReadWrite.All   (save approved PDFs to users' OneDrive)
#   Sites.ReadWrite.All   (SharePoint library / Teams channel uploads)
AZURE_CLIENT_ID=your-azure-app-client-id
AZURE_CLIENT_SECRET=your-azure-app-client-secret
AZURE_TENANT=your-tenant-id

# Service mailbox that system emails are sent from (required for Outlook email).
# GRAPH_MAIL_SENDER=the-circle@yourdomain.com

# Auto-save approved PDFs into the requester's OneDrive.
# GRAPH_ONEDRIVE_ENABLED=true
# GRAPH_ONEDRIVE_FOLDER=The Circle Approvals

# Organisation-wide SharePoint archive: set a document-library drive id, or a
# site id (its default library is used). Optional sub-folder path.
# GRAPH_SHAREPOINT_DRIVE_ID=
# GRAPH_SHAREPOINT_SITE_ID=
# GRAPH_SHAREPOINT_FOLDER=Approved Requests

# Optional Teams channel copy of every approved PDF.
# GRAPH_TEAM_ID=
# GRAPH_CHANNEL_ID=

# Shared secret for the scheduled jobs (/api/cron/*). Vercel sends it
# automatically as "Authorization: Bearer <CRON_SECRET>" when set.
# CRON_SECRET=

# ===========================================
# Optional: External Integrations
# ===========================================

# Slack App Token (alternative to incoming webhooks)
# SLACK_BOT_TOKEN=

# Teams (typically uses incoming webhooks, configured per workflow)

# ===========================================
# HRIMS Integration (Separate Supabase Project)
# ===========================================
# Production points these at the real HRIMS project. Staging can point them at a
# throwaway "HRIMS DEMO" clone for demos (see database/demo/README.md).
HRIMS_SUPABASE_URL=https://your-hrims-project.supabase.co
HRIMS_SUPABASE_SERVICE_ROLE_KEY=your-hrims-service-role-key

# ===========================================
# Demo mode (STAGING ONLY — never set in production)
# ===========================================
# When DEMO_MODE=true, an email/password Credentials provider is enabled so
# controlled, non-Microsoft demo accounts (the demo_users table) can sign in.
# NEXT_PUBLIC_DEMO_MODE=true reveals the demo login form on the landing page.
# Leave BOTH unset in production so Azure AD remains the only login path.
# DEMO_MODE=true
# NEXT_PUBLIC_DEMO_MODE=true

# ===========================================
# Email Service (Resend)
# ===========================================
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=The Circle <noreply@yourdomain.com>
